{
  "name": "pathway-prep-exams",
  "version": "1.0.0",
  "description": "Pathway Prep CBT exam platform",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "exam:install": "npm install --prefix exam-portal-design",
    "exam:build": "npm run exam:install && npm run build --prefix exam-portal-design",
    "render:build": "npm run cert:build-template && npm run template:build",
    "template:build": "node scripts/build-import-template.js",
    "cert:build-template": "node scripts/build-certificate-template.js",
    "migrate:exam-titles": "node scripts/migrate-exam-titles.js",
    "test:cert-email": "node scripts/test-certificate-email.js",
    "postinstall": "npm run cert:build-template && npm run template:build"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "resend": "^4.0.0",
    "xlsx": "^0.18.5"
  }
}
