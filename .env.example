PORT=4010

# Same Turso DB as pathway-prep-portal (shared candidates table)
TURSO_DATABASE_URL=libsql://your-database-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EXAM_ADMIN_KEY=replace-with-32-plus-character-random-secret
EXAM_JWT_SECRET=replace-with-another-32-plus-character-random-secret
# Optional separate pepper for OTP hashing (defaults to EXAM_JWT_SECRET)
# OTP_PEPPER=replace-with-optional-otp-pepper-secret

EXAM_PUBLIC_URL=https://exams.pathwayprep.online
PORTAL_HOME_URL=https://pathwayprep.online

RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Pathway Prep <portal@pathwayprep.online>
RESEND_DOMAIN=pathwayprep.online
RESEND_REPLY_TO=support@pathwayprep.online
EMAIL_BRAND_NAME=Pathway Prep Exams
